[Unit]
Description=MP3 Tag Editor - Frontend
After=network-online.target mp3tag-backend.service
Wants=mp3tag-backend.service

[Service]
Type=simple
User=kenneth
WorkingDirectory=/home/kenneth/mp3-tag-editor/frontend
ExecStart=/usr/bin/npm run dev -- --host 0.0.0.0
Restart=on-failure
RestartSec=5

EnvironmentFile=/home/kenneth/mp3-tag-editor/frontend/.env

[Install]
WantedBy=multi-user.target
